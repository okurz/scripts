#!/usr/bin/env python3
import json
import subprocess
import concurrent.futures

def run_gh(args):
    try:
        res = subprocess.run(['gh'] + args, capture_output=True, text=True, check=True)
        return res.stdout.strip()
    except subprocess.CalledProcessError:
        return None

def check_pr(pr):
    url, title = pr['url'], pr['title']
    # Skip review check if it's already filtered or if we hit repo-specific token issues
    decision = run_gh(['pr', 'view', url, '--json', 'reviewDecision', '--jq', '.reviewDecision'])
    if decision != "CHANGES_REQUESTED":
        return f"* {url} {title}"
    return None

def main():
    # Fetch open PRs with passing checks that aren't drafts
    query = 'gh search prs --author @me --state open --checks success --limit 100 --json url,title,repository,isDraft'
    raw_prs = run_gh(query.split()[1:])
    if not raw_prs:
        return

    prs = [p for p in json.loads(raw_prs) if not p['isDraft']]

    with concurrent.futures.ThreadPoolExecutor(max_workers=10) as executor:
        results = list(executor.map(check_pr, prs))

    print('\n'.join(filter(None, results)))

if __name__ == "__main__":
    main()
