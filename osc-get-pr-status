#!/usr/bin/env python3
import subprocess
import sys
import typer
from typing import Optional

app = typer.Typer(help="Extract CI/Build results and unresolvable reasons from OBS.")

def get_detailed_results(project: str, package: str):
    """
    Fetches detailed build results using 'osc results -v'.
    """
    try:
        result = subprocess.run(
            ["osc", "results", "-v", project, package],
            capture_output=True, text=True, check=True
        )
        return result.stdout
    except subprocess.CalledProcessError as e:
        typer.echo(f"Error running osc: {e.stderr}", err=True)
        return ""

def parse_unresolvables(output: str):
    """
    Parses the output of 'osc results -v' to extract the 'nothing provides' lines.
    """
    unresolvables = []
    lines = output.splitlines()
    for line in lines:
        if "nothing provides" in line:
            unresolvables.append(line.strip())
    return sorted(list(set(unresolvables)))

@app.command()
def extract(
    project: str = typer.Argument(..., help="The OBS project name (e.g. home:user:matrix)"),
    package: str = typer.Argument("matrix-synapse", help="The OBS package name"),
    verbose: bool = typer.Option(False, "--verbose", "-v", help="Print full output instead of just unresolvables")
):
    """
    Extract unresolvable dependencies from OBS build results.
    """
    output = get_detailed_results(project, package)
    if not output:
        raise typer.Exit(code=1)
    
    if verbose:
        typer.echo(output)
        return

    unresolvables = parse_unresolvables(output)
    if not unresolvables:
        typer.echo("No unresolvable issues found or build is still pending.")
    else:
        typer.echo("\n--- Unresolvable Dependencies ---")
        for item in unresolvables:
            typer.echo(item)

if __name__ == "__main__":
    app()
