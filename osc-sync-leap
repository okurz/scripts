#!/usr/bin/env python3
import os
import subprocess
import typer
import re
from typing import List, Optional

app = typer.Typer()

def run_command(cmd: List[str], dry_run: bool = False, capture_output: bool = False):
    if dry_run:
        if capture_output:
            if "rev-parse" in cmd: return "dryrunhash"
            if "remote" in cmd: return "gitea@src.opensuse.org:pool/generic-package.git"
            if "ls-tree" in cmd: return "file1\nfile2"
            if "rev-parse" in cmd and "--show-toplevel" in cmd: return os.getcwd()
        print(f"[DRY-RUN] {' '.join(cmd)}")
        return ""
    
    if capture_output:
        result = subprocess.run(cmd, check=True, capture_output=True, text=True)
        return result.stdout.strip()
    else:
        subprocess.run(cmd, check=True)
        return ""

@app.command()
def sync(
    branches: List[str] = typer.Option(["leap-16.0", "leap-16.1"], "--branch", "-b", help="Target Leap branches"),
    remote: str = typer.Option("okurz", "--remote", "-r", help="Your fork remote name"),
    upstream: str = typer.Option("origin", "--upstream", "-u", help="Upstream remote name"),
    dry_run: bool = typer.Option(False, "--dry-run", help="Show commands without executing them")
):
    """
    Sync Leap branches from Factory for ANY openSUSE package using the git-workflow.
    """
    # 0. Get package name from repository root directory name
    repo_root = run_command(["git", "rev-parse", "--show-toplevel"], capture_output=True, dry_run=dry_run)
    package_name = os.path.basename(repo_root) if repo_root else "package"
    
    # 1. Get Factory hash from upstream
    try:
        factory_hash = run_command(["git", "rev-parse", "--short", f"{upstream}/factory"], capture_output=True, dry_run=dry_run)
    except subprocess.CalledProcessError:
        factory_hash = run_command(["git", "rev-parse", "--short", "factory"], capture_output=True, dry_run=dry_run)
    
    print(f"Package: {package_name}")
    print(f"Factory hash: {factory_hash}")

    for branch in branches:
        sync_branch_name = f"{branch}-sync-{factory_hash}"
        
        print(f"\n--- Syncing {branch} ---")
        
        # Checkout target branch
        run_command(["git", "checkout", "-B", sync_branch_name, f"{upstream}/{branch}"], dry_run=dry_run)
        
        # Get list of files in root directory (excluding subdirectories)
        tracked_files_output = run_command(["git", "ls-tree", "--name-only", "HEAD"], capture_output=True, dry_run=dry_run)
        tracked_files = tracked_files_output.splitlines()
        
        files_to_remove = []
        for f in tracked_files:
            if dry_run or os.path.isfile(f):
                files_to_remove.append(f)

        if files_to_remove:
            run_command(["git", "rm"] + files_to_remove, dry_run=dry_run)
        
        # Checkout from factory
        run_command(["git", "checkout", f"{upstream}/factory", "--", "."], dry_run=dry_run)
        
        # Commit
        commit_msg = f"{package_name}: Update to factory at {factory_hash}"
        run_command(["git", "commit", "-m", commit_msg], dry_run=dry_run)
        
        # Push to the remote (your fork)
        run_command(["git", "push", "-f", remote, f"{sync_branch_name}:{sync_branch_name}"], dry_run=dry_run)
        
        # Create PR using tea
        upstream_url = run_command(["git", "remote", "get-url", upstream], capture_output=True, dry_run=dry_run)
        match = re.search(r'[:/]([^:/]+/[^:/]+)\.git$', upstream_url)
        repo_path = match.group(1) if match else upstream_url.split(":")[-1].replace(".git", "")
        
        tea_cmd = [
            "tea", "pr", "create",
            "--repo", repo_path,
            "--head", f"{remote}:{sync_branch_name}",
            "--base", branch,
            "--title", commit_msg,
            "--description", f"Automated sync of {package_name} from factory at {factory_hash}"
        ]
        run_command(tea_cmd, dry_run=dry_run)

if __name__ == "__main__":
    app()
